---
import type { CollectionEntry } from 'astro:content';
import BaseLayout from './BaseLayout.astro';
import AffiliateNotice from '../components/AffiliateNotice.astro';
import AffiliateLink from '../components/AffiliateLink.astro';
import AirfryerDecisionTool from '../components/AirfryerDecisionTool.astro';
import ArticleCard from '../components/ArticleCard.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import ComparisonTable from '../components/ComparisonTable.astro';

interface Props {
  review: CollectionEntry<'reviews'>;
  relatedArticles: CollectionEntry<'reviews'>[];
  sameCategoryComparisons?: CollectionEntry<'reviews'>[];
  sameCategoryGuides?: CollectionEntry<'reviews'>[];
}

const {
  review,
  relatedArticles,
  sameCategoryComparisons = [],
  sameCategoryGuides = []
} = Astro.props;
const data = review.data;
const site = Astro.site ?? new URL('https://kieskeuken.nl');
const canonical = new URL(`/${data.slug}/`, site).toString();
const categoryLabel = {
  huishoudelijk: 'Huishoudelijk',
  keuken: 'Keuken',
  schoonmaken: 'Schoonmaken',
  tuin: 'Tuin'
}[data.category];
const categoryUrl = `/categorie/${data.category}/`;
const isA2AirfryerExperiment = data.slug === 'beste-airfryer-2026';

const bestProduct = data.products[0];
const extractAsin = (url: string): string => {
  const match = url.match(/\/dp\/([A-Z0-9]+)/);
  return match ? match[1] : '';
};
const amazonSearch = (name: string) => `https://www.amazon.nl/s?k=${encodeURIComponent(name.replace(/\*\*/g, '').trim())}&tag=kieskeukennl-21`;

// Parse priceRange strings like "EUR 500-2000" or "EUR 200-3000" into numeric bounds
const parsePriceRange = (pr: string): { low: number; high: number } | null => {
  const match = pr.match(/(\d+)\s*[-–]\s*(\d+)/);
  if (!match) return null;
  const low = parseInt(match[1], 10);
  const high = parseInt(match[2], 10);
  if (low > 0 && high >= low) return { low, high };
  return null;
};
const articlePriceRange = parsePriceRange(data.priceRange);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: site.toString() },
    { '@type': 'ListItem', position: 2, name: categoryLabel, item: new URL(`/categorie/${data.category}/`, site).toString() },
    { '@type': 'ListItem', position: 3, name: data.featuredProduct, item: canonical }
  ]
};

// Build individual Offer objects from product data for rich-pricing eligibility
const productOffers = data.products.slice(0, 10).map((p: any) => {
  const pr = parsePriceRange(p.priceRange || '');
  const offer: any = {
    '@type': 'Offer',
    'priceCurrency': 'EUR',
    'availability': 'https://schema.org/InStock',
    'url': p.affiliateLink,
    'seller': { '@type': 'Organization', 'name': 'Amazon NL' }
  };
  if (pr) { offer.price = pr.low; }
  return offer;
});

// Product schema with editorial Review. No aggregateRating — a single editorial
// rating doesn't qualify as an "aggregate" and Google flags ratingCount:1 as spam.
const schema: any = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: data.featuredProduct,
  description: data.description,
  category: categoryLabel,
  review: {
    '@type': 'Review',
    author: {
      '@type': 'Organization',
      name: 'Beste Apparaten'
    },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: data.rating,
      bestRating: 5,
      worstRating: 1
    },
    name: data.title,
    reviewBody: data.description
  }
};

// AggregateOffer with real price bounds when we can parse them
if (articlePriceRange) {
  schema.offers = {
    '@type': 'AggregateOffer',
    'priceCurrency': 'EUR',
    'offerCount': data.products.length,
    'lowPrice': articlePriceRange.low,
    'highPrice': articlePriceRange.high,
    'availability': 'https://schema.org/InStock'
  };
}
// Individual offers for rich-result eligibility
schema.hasOfferCatalog = {
  '@type': 'OfferCatalog',
  'name': `${data.featuredProduct} — beschikbare aanbiedingen`,
  'itemListElement': productOffers
};
const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': canonical + '#article',
  'headline': data.title,
  'description': data.description,
  'datePublished': data.date.toISOString().split('T')[0],
  'dateModified': data.date.toISOString().split('T')[0],
  'author': {
    '@type': 'Organization',
    'name': 'Beste Apparaten',
    '@id': site.toString() + '#organization'
  },
  'publisher': {
    '@type': 'Organization',
    '@id': site.toString() + '#organization'
  },
  'inLanguage': 'nl-NL',
  'about': {
    '@type': 'Product',
    'name': data.featuredProduct,
    '@id': canonical + '#product'
  },
  'mainEntityOfPage': {
    '@type': 'WebPage',
    '@id': canonical
  }
};

// FAQPage schema — only when the article has FAQ frontmatter
const faqSchema = data.faq && data.faq.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  'mainEntity': data.faq.map((item: { q: string; a: string }) => ({
    '@type': 'Question',
    'name': item.q,
    'acceptedAnswer': {
      '@type': 'Answer',
      'text': item.a
    }
  }))
} : null;
---

<BaseLayout title={`${data.title} | Beste Apparaten`} description={data.description} canonicalUrl={canonical} ogType="article">
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

  <Breadcrumb
    category={data.category}
    categoryLabel={categoryLabel || 'Overig'}
    featuredProduct={isA2AirfryerExperiment ? 'Beste airfryer 2026' : data.featuredProduct}
  />

  <article class:list={['mx-auto max-w-6xl px-4 py-6 sm:px-6 lg:px-8', isA2AirfryerExperiment && 'a2-airfryer-page']}>
    <header class:list={['grid gap-8 lg:grid-cols-[1.6fr_0.9fr] lg:items-end', isA2AirfryerExperiment && 'a2-editorial-hero']}>
      <div>
        <p class:list={['text-sm font-bold uppercase tracking-[0.16em] text-leaf', isA2AirfryerExperiment && 'a2-hero__eyebrow']}>
          {isA2AirfryerExperiment ? 'De onafhankelijke airfryer-keuzehulp' : `${categoryLabel} / koopgids ${data.modelYear}`}
        </p>
        <h1 class:list={['mt-4 max-w-4xl font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl', isA2AirfryerExperiment && 'a2-hero__title']}>
          {isA2AirfryerExperiment ? (
            <>
              <span>Beste airfryer 2026</span>
              <span>Welke past écht bij jouw keuken?</span>
            </>
          ) : data.title}
        </h1>
        <p class:list={['mt-5 max-w-3xl text-lg leading-8 text-muted', isA2AirfryerExperiment && 'a2-hero__intro']}>{data.description}</p>
        <div class:list={['mt-6 flex flex-wrap gap-3 text-sm font-semibold', isA2AirfryerExperiment && 'a2-hero__meta']}>
          <span class="rounded bg-[#edf4f2] px-3 py-1.5 text-leaf">
            {isA2AirfryerExperiment ? '5 modellen, eerlijk vergeleken' : `Score ${data.rating.toFixed(1)}/5`}
          </span>
          <span class="rounded bg-linen px-3 py-1.5 text-muted">{isA2AirfryerExperiment ? '3 vragen naar je match' : data.priceRange}</span>
          <span class="rounded bg-linen px-3 py-1.5 text-muted">{isA2AirfryerExperiment ? 'Geen account nodig' : data.readingTime}</span>
          <time class="rounded bg-linen px-3 py-1.5 text-muted" datetime={data.date.toISOString()}>
            Update {data.date.toLocaleDateString('nl-NL', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>
      </div>

      {isA2AirfryerExperiment ? (
        <aside class="a2-hero__route" aria-label="Zo werkt de keuzehulp">
          <p class="a2-hero__route-label">Begin niet bij een merk. Begin bij je keuken.</p>
          <h2>Van twijfel naar een shortlist in 30 seconden.</h2>
          <ol>
            <li><span>1</span><div><strong>Vertel hoe je kookt</strong><small>Huishouden, manden en prioriteit</small></div></li>
            <li><span>2</span><div><strong>Zie waarom het past</strong><small>Een uitlegbare match, geen zwarte doos</small></div></li>
            <li><span>3</span><div><strong>Vergelijk rustig verder</strong><small>Prijs, minpunten en alternatieven blijven zichtbaar</small></div></li>
          </ol>
          <a href="#airfryer-keuzehulp">Start de keuzehulp <span aria-hidden="true">↓</span></a>
          <p class="a2-hero__route-note">Geen login · geen opgeslagen antwoorden</p>
        </aside>
      ) : (
        <aside class="rounded border border-[#dfe8e5] bg-[#f3faf7] p-5">
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Beste keuze</p>
          <h2 class="mt-2 font-serif text-2xl font-semibold text-ink">{bestProduct.name}</h2>
          <p class="mt-3 text-sm leading-6 text-muted">{bestProduct.verdict}</p>
          <div class="mt-5">
            <AffiliateLink
              merchantId="amazon-nl"
              siteId="kieskeuken"
              params={{ asin: extractAsin(bestProduct.affiliateLink) }}
              class="inline-flex rounded bg-leaf px-4 py-2 text-sm font-bold text-white hover:bg-[#1f514b]"
            >
              Bekijk beste prijs
            </AffiliateLink>
          </div>
          <a class="mt-3 inline-flex rounded bg-[#232f3e] px-4 py-2 text-sm font-bold text-white hover:bg-[#131921]" href={amazonSearch(bestProduct.name)} rel="nofollow sponsored" target="_blank" data-affiliate-merchant="amazon-nl" data-affiliate-site="kieskeuken">
            Zoek op Amazon
          </a>
        </aside>
      )}
    </header>

    {isA2AirfryerExperiment && <AirfryerDecisionTool products={data.products} />}

    <section class:list={['mt-10 grid gap-4 md:grid-cols-2', isA2AirfryerExperiment && 'a2-balance-sheet']}>
      <div class:list={['rounded border border-[#e6ded2] bg-paper p-5', isA2AirfryerExperiment && 'a2-balance-sheet__card a2-balance-sheet__card--plus']}>
        {isA2AirfryerExperiment && <p class="a2-balance-sheet__kicker">Wat je wint</p>}
        <h2 class="font-serif text-2xl font-semibold text-ink">Pluspunten</h2>
        <ul class="mt-4 space-y-2 text-muted">
          {data.pros.map((item) => <li class="flex gap-2"><span class="font-bold text-leaf">+</span><span>{item}</span></li>)}
        </ul>
      </div>
      <div class:list={['rounded border border-[#e6ded2] bg-paper p-5', isA2AirfryerExperiment && 'a2-balance-sheet__card a2-balance-sheet__card--minus']}>
        {isA2AirfryerExperiment && <p class="a2-balance-sheet__kicker">Waar je op let</p>}
        <h2 class="font-serif text-2xl font-semibold text-ink">Minpunten</h2>
        <ul class="mt-4 space-y-2 text-muted">
          {data.cons.map((item) => <li class="flex gap-2"><span class="font-bold text-clay">-</span><span>{item}</span></li>)}
        </ul>
      </div>
    </section>

    <section class:list={['mt-10', isA2AirfryerExperiment && 'a2-shortlist']}>
      {isA2AirfryerExperiment && <p class="a2-shortlist__eyebrow">De shortlist</p>}
      <h2 class="font-serif text-3xl font-semibold text-ink">
        {isA2AirfryerExperiment ? 'Vijf sterke keuzes, zonder verkooppraat' : 'Vergelijking in het kort'}
      </h2>
      <p class="mt-2 max-w-3xl text-muted">
        {isA2AirfryerExperiment
          ? 'Bekijk na je match ook de alternatieven. De verschillen in formaat, prijs en dagelijks gebruik zijn belangrijker dan één winnaar voor iedereen.'
          : 'De links hieronder bevatten affiliate links naar Amazon.nl. Coolblue en andere aanbieders volgen zodra deze zijn goedgekeurd. Bekijk prijzen, specificaties en minpunten in één oogopslag.'}
      </p>
      <div class="mt-5">
        <ComparisonTable
          products={data.products}
          trackDirectAmazonSearch={isA2AirfryerExperiment}
          enhancedAirfryerLayout={isA2AirfryerExperiment}
        />
      </div>
    </section>

    <div class="mt-10">
      {isA2AirfryerExperiment ? (
        <aside class="border-y border-[#e8e1d7] py-3 text-sm leading-6 text-muted">
          <p><strong class="font-semibold text-ink">Affiliate melding:</strong> sommige links gaan naar Amazon.nl; bij een aankoop kan Beste Apparaten commissie ontvangen, zonder extra kosten voor jou. Dit verandert onze rangschikking niet.</p>
        </aside>
      ) : <AffiliateNotice />}
    </div>

    <div class="prose-review mx-auto mt-10 max-w-3xl">
      <slot />
    </div>

    <section class="mt-14 rounded border border-[#dfe8e5] bg-[#f3faf7] p-6">
      <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Slimme vervolgstap</p>
          <h2 class="mt-2 font-serif text-3xl font-semibold text-ink">Vergelijk verder voordat je koopt</h2>
          <p class="mt-2 max-w-3xl text-sm leading-6 text-muted">
            Veel bezoekers komen via één product binnen, maar twijfelen eigenlijk tussen twee apparaattypes of prijsklassen.
            Gebruik deze interne keuzehulpen om de beste match voor je huishouden te vinden.
          </p>
        </div>
        <div class="flex flex-wrap gap-2 text-sm font-bold">
          <a href="/vergelijken/" class="rounded bg-leaf px-3 py-2 text-white hover:bg-[#1f514b]">Alle X vs Y vergelijkingen</a>
          <a href="/apparaat-kiezen/" class="rounded border border-leaf px-3 py-2 text-leaf hover:bg-[#edf4f2]">Beslisboom openen</a>
          <a href={categoryUrl} class="rounded border border-[#cbbda9] px-3 py-2 text-ink hover:bg-paper">Meer in {categoryLabel}</a>
        </div>
      </div>

      <div class="mt-6 grid gap-4 lg:grid-cols-2">
        {sameCategoryComparisons.length > 0 && (
          <div class="rounded border border-[#e6ded2] bg-paper p-5">
            <h3 class="font-serif text-xl font-semibold text-ink">Populaire vergelijkingen in {categoryLabel}</h3>
            <ul class="mt-4 space-y-3 text-sm">
              {sameCategoryComparisons.map((article) => (
                <li>
                  <a href={`/${article.data.slug}/`} class="font-semibold text-leaf hover:text-[#1f514b]">
                    {article.data.title}
                  </a>
                  <p class="mt-1 text-muted">{article.data.description}</p>
                </li>
              ))}
            </ul>
          </div>
        )}

        {sameCategoryGuides.length > 0 && (
          <div class="rounded border border-[#e6ded2] bg-paper p-5">
            <h3 class="font-serif text-xl font-semibold text-ink">Beste koopgidsen naast deze review</h3>
            <ul class="mt-4 space-y-3 text-sm">
              {sameCategoryGuides.map((article) => (
                <li class="flex items-start justify-between gap-3">
                  <div>
                    <a href={`/${article.data.slug}/`} class="font-semibold text-leaf hover:text-[#1f514b]">
                      {article.data.title}
                    </a>
                    <p class="mt-1 text-muted">{article.data.priceRange} · {article.data.readingTime}</p>
                  </div>
                  <span class="shrink-0 rounded bg-[#edf4f2] px-2 py-0.5 text-xs font-bold text-leaf">
                    {article.data.rating.toFixed(1)}/5
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </section>

    <!-- FAQ section with FAQPage structured data -->
    {data.faq && data.faq.length >= 3 && (
      <>
        <script type="application/ld+json" set:html={JSON.stringify({
          '@context': 'https://schema.org',
          '@type': 'FAQPage',
          mainEntity: data.faq.map((item) => ({
            '@type': 'Question',
            name: item.q,
            acceptedAnswer: {
              '@type': 'Answer',
              text: item.a
            }
          }))
        })} />
        <section class="mt-14">
          <h2 class="font-serif text-3xl font-semibold text-ink">Veelgestelde vragen</h2>
          <div class="mt-6 space-y-4">
            {data.faq.map((item) => (
              <details class="rounded border border-[#e6ded2] bg-paper p-4 group">
                <summary class="cursor-pointer font-semibold text-ink hover:text-leaf transition text-base">
                  {item.q}
                </summary>
                <p class="mt-3 text-muted leading-relaxed">{item.a}</p>
              </details>
            ))}
          </div>
        </section>
      </>
    )}

    <section class="mt-14">
      <h2 class="font-serif text-3xl font-semibold text-ink">Gerelateerde koopgidsen</h2>
      <div class="mt-6 grid gap-5 md:grid-cols-3">
        {relatedArticles.map((article) => <ArticleCard article={article} />)}
      </div>
    </section>
  </article>
</BaseLayout>

<style is:global>
  .a2-airfryer-page {
    --a2-forest: #153f39;
    --a2-forest-deep: #0d2f2b;
    --a2-cream: #fffaf0;
    --a2-gold: #e6bd74;
    --a2-coral: #d77452;
    padding-top: clamp(1rem, 3vw, 2rem);
  }

  .a2-editorial-hero {
    position: relative;
    overflow: hidden;
    border: 1px solid #e4ddd0;
    border-radius: 2rem;
    background:
      radial-gradient(circle at 84% 12%, rgba(230, 189, 116, 0.16), transparent 28rem),
      linear-gradient(145deg, #fffdf8 0%, #f6f1e8 100%);
    padding: clamp(1.4rem, 5vw, 3.4rem);
    box-shadow: 0 2rem 5rem rgba(31, 41, 51, 0.08);
  }

  .a2-editorial-hero::after {
    position: absolute;
    top: 0;
    left: 0;
    width: 7.5rem;
    height: 0.3rem;
    border-radius: 0 0 999px 0;
    background: linear-gradient(90deg, var(--a2-forest), var(--a2-gold));
    content: '';
  }

  .a2-hero__eyebrow { color: var(--a2-coral); font-size: 0.72rem; }

  .a2-hero__title {
    display: grid;
    max-width: 13ch;
    gap: 0.15em;
    font-size: clamp(2.65rem, 7vw, 5.6rem);
    letter-spacing: -0.052em;
    line-height: 0.91;
  }

  .a2-hero__title span:last-child {
    color: var(--a2-forest);
    font-size: 0.56em;
    font-style: italic;
    letter-spacing: -0.025em;
    line-height: 1.06;
  }

  .a2-hero__intro { max-width: 40rem; color: #596764; font-size: clamp(1rem, 2vw, 1.15rem); line-height: 1.7; }

  .a2-hero__meta { gap: 0.45rem; }

  .a2-hero__meta > * {
    border: 1px solid rgba(21, 63, 57, 0.1);
    border-radius: 999px;
    background: rgba(255, 253, 248, 0.72);
    padding: 0.42rem 0.68rem;
    color: #4f625e;
    font-size: 0.68rem;
    backdrop-filter: blur(8px);
  }

  .a2-hero__meta > :first-child { background: #eaf3ef; color: var(--a2-forest); }

  .a2-hero__route {
    position: relative;
    overflow: hidden;
    border-radius: 1.45rem;
    background: var(--a2-forest-deep);
    padding: clamp(1.25rem, 3vw, 2rem);
    box-shadow: 0 1.5rem 3.5rem rgba(13, 47, 43, 0.2);
    color: var(--a2-cream);
  }

  .a2-hero__route::before {
    position: absolute;
    right: -4rem;
    bottom: -5rem;
    width: 12rem;
    height: 12rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(230, 189, 116, 0.25), transparent 68%);
    content: '';
    pointer-events: none;
  }

  .a2-hero__route-label {
    margin: 0;
    color: var(--a2-gold);
    font-size: 0.68rem;
    font-weight: 850;
    letter-spacing: 0.13em;
    line-height: 1.5;
    text-transform: uppercase;
  }

  .a2-hero__route h2 {
    max-width: 15ch;
    margin: 0.65rem 0 0;
    font-family: Fraunces, ui-serif, Georgia, serif;
    font-size: clamp(1.55rem, 3vw, 2.2rem);
    font-weight: 600;
    letter-spacing: -0.025em;
    line-height: 1.05;
  }

  .a2-hero__route ol { display: grid; gap: 0.8rem; margin: 1.35rem 0 0; padding: 0; list-style: none; }

  .a2-hero__route li { display: grid; grid-template-columns: 1.6rem minmax(0, 1fr); gap: 0.65rem; align-items: start; }

  .a2-hero__route li > span {
    display: grid;
    width: 1.55rem;
    height: 1.55rem;
    place-items: center;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    color: var(--a2-gold);
    font-size: 0.65rem;
    font-weight: 850;
  }

  .a2-hero__route li div { display: grid; gap: 0.05rem; }
  .a2-hero__route li strong { font-size: 0.8rem; }
  .a2-hero__route li small { color: rgba(255, 250, 240, 0.58); font-size: 0.7rem; line-height: 1.4; }

  .a2-hero__route > a {
    position: relative;
    display: flex;
    width: 100%;
    align-items: center;
    justify-content: space-between;
    margin-top: 1.35rem;
    border-radius: 999px;
    background: var(--a2-cream);
    padding: 0.78rem 1rem;
    color: var(--a2-forest-deep);
    font-size: 0.78rem;
    font-weight: 850;
    text-decoration: none;
  }

  .a2-hero__route > a:hover { background: #fff; }
  .a2-hero__route-note { margin: 0.65rem 0 0; text-align: center; color: rgba(255, 250, 240, 0.5); font-size: 0.64rem; }

  .a2-balance-sheet { margin-top: clamp(2.5rem, 6vw, 4.5rem); }

  .a2-balance-sheet__card {
    position: relative;
    overflow: hidden;
    border-radius: 1.35rem;
    padding: clamp(1.2rem, 3vw, 1.8rem);
    box-shadow: 0 1rem 2.5rem rgba(31, 41, 51, 0.055);
  }

  .a2-balance-sheet__card::before { position: absolute; top: 0; right: 0; left: 0; height: 0.22rem; content: ''; }
  .a2-balance-sheet__card--plus::before { background: linear-gradient(90deg, var(--a2-forest), #81ad9f); }
  .a2-balance-sheet__card--minus::before { background: linear-gradient(90deg, var(--a2-coral), #e6bd74); }

  .a2-balance-sheet__kicker {
