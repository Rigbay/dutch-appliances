---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';

const reviews = (await getCollection('reviews', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const comparisonCount = reviews.filter((review) => review.data.slug.includes('-vs-')).length;

const categories = [
  { href: '/categorie/keuken/', label: 'Keuken', text: 'Airfryers, koffiemachines, waterkokers, broodroosters, magnetrons en stoomovens.' },
  { href: '/categorie/schoonmaken/', label: 'Schoonmaken', text: 'Stofzuigers, robotstofzuigers en draadloze steelstofzuigers voor drukke huishoudens.' },
  { href: '/categorie/huishoudelijk/', label: 'Huishoudelijk', text: 'Praktische apparaten die dagelijks werk in huis sneller en lichter maken.' },
  { href: '/categorie/tuin/', label: 'Tuin', text: 'Grasmaaiers, barbecues, heggenscharen, tuinverwarming en gereedschap voor buiten.' }
];

const keuzehulpen = [
  { href: '/apparaat-kiezen/', label: 'Welk apparaat kiezen?', text: 'Nieuwe beslisboom per situatie: snel avondeten, minder stofzuigen, energie besparen, zomerkoeling en tuinwerk.' },
  { href: '/apparaten-per-situatie/', label: 'Beste apparaten per situatie', text: 'Nieuwe SEO-hub voor gezin, kleine keuken, student, huisdieren, allergie, energie besparen, zomer en tuin.' },
  { href: '/stroomkosten-apparaten/', label: 'Stroomkosten per apparaat', text: 'Nieuwe energiekosten-tabel: droger, koelkast, vaatwasser, airco, inductie, airfryer en meer doorgerekend per jaar.' },
  { href: '/alle-apparaten/', label: 'Alle apparaten in één overzicht', text: 'Het complete overzicht: alle 171 koopgidsen in één scannable tabel per categorie.' },
  { href: '/top-15/', label: 'Top 15 apparaten van 2026', text: 'Snelle shortlist voor bezoekers die meteen de populairste keuzes willen zien.' },
  { href: '/vergelijkingen/', label: `🆚 Alle ${comparisonCount} apparaat-vergelijkingen`, text: 'Directe vergelijkingen: airfryer vs friteuse, inductie vs gas, robotstofzuiger vs stofzuiger en meer. Filter op categorie.' },
  { href: '/vergelijking/', label: 'Alle apparaten per productgroep', text: 'Het overzicht met alle koopgidsen per categorie en productgroep, met context.' },
  { href: '/budget/', label: 'Budget apparaten onder €100', text: '60+ beste budgetkeuzes voor elk huishouden — van airfryer tot waterkoker, onder €100.' },
  { href: '/onder-50-euro/', label: '🪙 Apparaten onder €50', text: 'Nieuwe pagina: 259 producten onder €50 — waterkokers, broodroosters, kruimeldieven en meer met directe Amazon links.' },
  { href: '/zomer-apparaten/', label: '☀️ Zomer apparaten 2026', text: 'Alles voor de zomer: barbecues, airco\'s, ijsmachines, tuingereedschap en meer — met kooptips en checklist.' },
  { href: '/middenklasse/', label: '🏆 Middenklasse €100–€300', text: 'Nieuwe pagina: de sweet spot voor huishoudelijke apparaten. Betrouwbare merken, energiezuinige motoren, beste prijs-kwaliteit — zonder premium prijs.' },
  { href: '/prijsklassen/', label: '💰 Beste per prijsklasse 2026', text: 'NIEUW: Alle 59 keukenapparaten ingedeeld op budget, middenklasse en premium. Vind direct het beste apparaat binnen jouw budget — met Amazon NL prijzen.' },
  { href: '/beste-merken/', label: '🏷️ Beste merken vergeleken', text: 'Nieuwe pagina: Miele vs Bosch vs Siemens vs Philips — 15 topmerken vergeleken per apparaatcategorie. Premium, middenklasse en budget.' },
  { href: '/nieuwe-keuken-inrichten/', label: '🏗️ Nieuwe keuken inrichten 2026', text: 'Complete gids voor het inrichten van een nieuwe keuken: budgetplanner, checklist, inbouw vs vrijstaand, en alle essentiële apparaten met Amazon NL links.' }
];
---

<BaseLayout
  title="Beste Apparaten 2026: Nederlandse koopgidsen voor huishoudelijke apparaten"
  description="Nederlandstalige koopgidsen voor de beste airfryer, stofzuiger, koffiemachine, waterkoker en andere apparaten in 2026."
>
  <section class="border-b border-[#e8e1d7] bg-linen">
    <div class="mx-auto grid max-w-6xl gap-8 px-4 py-12 sm:px-6 lg:grid-cols-[1.35fr_0.65fr] lg:px-8">
      <div>
        <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Koopgidsen voor Nederland</p>
        <h1 class="mt-4 max-w-4xl font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl">
          Beste huishoudelijke apparaten van 2026, helder vergeleken.
        </h1>
        <p class="mt-5 max-w-2xl text-lg leading-8 text-muted">
          Beste Apparaten helpt je snel kiezen met nuchtere vergelijkingen, bekende minpunten, budgetadvies en directe Amazon.nl links naar de beste deals.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a class="rounded bg-leaf px-5 py-3 text-sm font-bold text-white hover:bg-[#1f514b]" href="#laatste-reviews">Bekijk reviews</a>
          <a class="rounded border border-leaf bg-white px-5 py-3 text-sm font-bold text-leaf hover:bg-[#edf4f2]" href="/top-15/">Top 15 van 2026 →</a>
          <a class="rounded border border-[#cbbda9] px-5 py-3 text-sm font-bold text-ink hover:bg-paper" href="/over/">Hoe we vergelijken</a>
        </div>
      </div>
      <div class="rounded border border-[#e1d8ca] bg-paper p-5">
        <p class="font-serif text-2xl font-semibold text-ink">In cijfers</p>
        <dl class="mt-5 grid gap-4 text-sm">
          <div class="flex items-center justify-between gap-4 border-b border-[#eee7dd] pb-3">
            <dt class="text-muted">Live koopgidsen</dt>
            <dd class="font-bold text-leaf">{reviews.length}</dd>
          </div>
          <div class="flex items-center justify-between gap-4 border-b border-[#eee7dd] pb-3">
            <dt class="text-muted">Directe vergelijkingen</dt>
            <dd class="font-bold text-ink">{comparisonCount}</dd>
          </div>
          <div class="flex items-center justify-between gap-4">
            <dt class="text-muted">Affiliate partner</dt>
            <dd class="font-bold text-ink">Amazon NL</dd>
          </div>
        </dl>
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <h2 class="font-serif text-3xl font-semibold text-ink">Categorieen</h2>
    <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-4">
      {categories.map((category) => (
        <a class="rounded border border-[#e6ded2] bg-paper p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft" href={category.href}>
          <span class="text-sm font-bold uppercase tracking-[0.14em] text-leaf">{category.label}</span>
          <p class="mt-3 text-sm leading-6 text-muted">{category.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="rounded border border-[#dfe8e5] bg-[#f3faf7] p-6">
      <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
        <div>
          <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Keuzehulp</p>
          <h2 class="mt-2 font-serif text-3xl font-semibold text-ink">Begin met vergelijken</h2>
          <p class="mt-2 max-w-3xl text-muted">Deze pagina's vangen zoekers met hoge koopintentie: vergelijken, shortlist maken en daarna doorklikken naar de productgids met affiliate links.</p>
        </div>
        <a class="text-sm font-bold text-leaf hover:text-[#1f514b]" href="/vergelijking/">Open alle vergelijkingen →</a>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
        {keuzehulpen.map((item) => (
          <a class="rounded bg-paper p-4 shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft" href={item.href}>
            <span class="font-serif text-lg font-semibold text-ink">{item.label}</span>
            <p class="mt-2 text-sm leading-6 text-muted">{item.text}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="laatste-reviews" class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <div class="flex flex-col gap-2 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h2 class="font-serif text-3xl font-semibold text-ink">Laatste reviews</h2>
        <p class="mt-2 text-muted">Koopgidsen met vergelijkingstabel, budgetkeuze en FAQ.</p>
      </div>
      <a class="text-sm font-bold text-leaf hover:text-[#1f514b]" href="/categorie/keuken/">Start bij keukenapparaten</a>
    </div>
    <div class="mt-6 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {reviews.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="max-w-3xl">
      <h2 class="font-serif text-3xl font-semibold text-ink">Over deze site</h2>
      <p class="mt-4 text-muted">
        Deze site is gebouwd als statische Astro-site: snel, onderhoudsarm en geschikt om wekelijks nieuwe Markdown-artikelen te publiceren. De aanbevelingen zijn gebaseerd op productspecificaties, prijsniveau, beschikbare gebruikerservaringen en bekende aandachtspunten. Er wordt niet gedaan alsof elk product hands-on is getest.
      </p>
    </div>
  </section>
</BaseLayout>
