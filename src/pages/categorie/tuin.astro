---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const reviews = (await getCollection('reviews', ({ data }) => !data.draft && data.category === 'tuin'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Beste tuinartikelen 2026 vergelijken | Beste Apparaten"
  description="Koopgidsen voor grasmaaiers, barbecues, tuinverlichting, terrasverwarmers en tuingereedschap in 2026. Vergelijk de beste keuzes voor de Nederlandse tuin."
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Categorie</p>
    <h1 class="mt-3 font-serif text-4xl font-semibold text-ink">Tuin & Buiten</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-muted">
      Alles voor de Nederlandse tuin: van grasmaaiers en barbecues tot sfeerverlichting en terrasverwarmers. Eerlijk beoordeeld op gebruiksgemak, duurzaamheid en prijs-kwaliteit.
    </p>
    <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {reviews.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
