---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const reviews = (await getCollection('reviews', ({ data }) => !data.draft && data.category === 'schoonmaken'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Beste schoonmaakapparaten 2026 vergelijken | Beste Apparaten"
  description="Vergelijk stofzuigers, robotstofzuigers en draadloze steelstofzuigers voor Nederlandse huishoudens in 2026."
>
  <section class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf"><a href="/categorie/" class="hover:underline">Categorie</a> &rsaquo; Schoonmaken</p>
    <h1 class="mt-3 font-serif text-4xl font-semibold text-ink">Schoonmaken</h1>
    <p class="mt-4 max-w-3xl text-lg leading-8 text-muted">
      Van klassieke sledestofzuiger tot robot met dweilstation: deze gidsen leggen uit welk apparaat echt past bij vloer, huisdieren, drempels en onderhoud.
    </p>
    <div class="mt-8 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {reviews.map((article) => <ArticleCard article={article} />)}
    </div>
  </section>
</BaseLayout>
