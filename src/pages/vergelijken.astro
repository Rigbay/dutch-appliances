---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews', ({ data }) => !data.draft);

// Extract all comparison ("vs") articles
const vsArticles = allReviews.filter(r => r.data.slug.includes('-vs-'));

// Group them by category
const vsByCategory: Record<string, { label: string; emoji: string; articles: any[] }> = {
  keuken: { label: 'Keukenapparaten vergelijken', emoji: '🍳', articles: [] },
  schoonmaken: { label: 'Schoonmaken & stofzuigen vergelijken', emoji: '🧹', articles: [] },
  huishoudelijk: { label: 'Huishoudelijke apparaten vergelijken', emoji: '🏠', articles: [] },
  tuin: { label: 'Tuin & buiten vergelijken', emoji: '🌿', articles: [] },
};

for (const article of vsArticles) {
  const cat = article.data.category;
  if (vsByCategory[cat]) {
    vsByCategory[cat].articles.push(article);
  }
}

// FAQ structured data
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Welke airfryer is beter: Philips Airfryer of een goedkoper alternatief?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Philips Airfryers hebben consistent de beste gebruikersreviews door hun Rapid Air-technologie en duurzaamheid. Een goedkoper alternatief zoals een Inventum of Princess biedt prima prestaties voor de helft van de prijs, maar is vaak luider en minder gelijkmatig in het bakken. Bekijk onze airfryer vergelijking voor de beste keuze per budget.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wat is beter: een robotstofzuiger of een gewone stofzuiger?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Een robotstofzuiger is perfect voor dagelijks onderhoud op harde vloeren en laagpolig tapijt, maar vervangt een gewone stofzuiger niet volledig. Voor dieptereiniging, trappen, en hoeken heb je nog steeds een gewone stofzuiger nodig. De ideale combinatie is een robotstofzuiger voor dagelijks gebruik + een steelstofzuiger voor wekelijkse schoonmaak.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is inductie koken echt zuiniger dan gas?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ja, inductie koken is 50% energiezuiniger dan gas en 30% zuiniger dan keramisch koken. De warmte wordt direct in de pan opgewekt zonder verlies naar de omgeving. Daarnaast is inductie veiliger (geen open vlam), sneller (water kookt in 2 minuten), en makkelijker schoon te maken. Met de huidige gasprijzen verdien je de investering in 3-4 jaar terug.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wat is het verschil tussen een warmtepompdroger en condensdroger?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Een warmtepompdroger gebruikt 50-60% minder energie dan een condensdroger omdat hij de warme lucht hergebruikt in plaats van af te voeren. Een warmtepompdroger kost €100-200 meer in aanschaf, maar bespaart €80-130 per jaar aan stroom — terugverdiend in 2 jaar. Wel droogt hij iets langzamer (130 vs 90 minuten gemiddeld) en moet je het condensorfilter elke 1-2 maanden schoonmaken.',
      },
    },
    {
      '@type': 'Question',
      name: 'Is een Quooker de investering waard vergeleken met een waterkoker?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Een Quooker is een luxe-investering (€1.200-1.800 incl. installatie) die direct kokend water levert uit de kraan. Een waterkoker kost €15-80 en doet hetzelfde in 2-3 minuten. Voor de meeste huishoudens is een waterkoker ruim voldoende. Een Quooker is vooral interessant als je vaak kokend water nodig hebt (thee, pasta, schoonmaken) en bereid bent te betalen voor gemak.',
      },
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Apparaat Vergelijkingen 2026 — Directe X vs Y Vergelijkingen',
  description: '40 directe vergelijkingen van huishoudelijke apparaten: airfryer vs friteuse, robotstofzuiger vs stofzuiger, inductie vs gas, warmtepompdroger vs condensdroger en meer.',
  numberOfItems: vsArticles.length,
  itemListElement: vsArticles.map((article, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'Product',
      name: article.data.title,
      url: `https://rigbay.github.io/dutch-appliances/${article.data.slug}/`,
    },
  })),
};
---

<BaseLayout
  title="Apparaat Vergelijkingen 2026: Direct X vs Y Vergelijken | Beste Apparaten"
  description: '40 directe apparaatvergelijkingen: airfryer vs friteuse, robotstofzuiger vs gewone stofzuiger, inductie vs gas, warmtepompdroger vs condensdroger en meer. Eerlijke head-to-head keuzehulp met Amazon NL links (kieskeukennl-21).',
  structuredData={[faqSchema, itemListSchema]}
>
  <!-- HERO -->
  <section class="border-b border-[#e8e1d7] bg-linen">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Keuzehulp</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold leading-tight text-ink sm:text-5xl">
        Apparaat X vs Y: {vsArticles.length} Directe Vergelijkingen voor 2026
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-muted">
        Twijfel je tussen twee apparaten? Airfryer of friteuse? Robotstofzuiger of gewone stofzuiger? Inductie of gas? 
        Hier vind je eerlijke, gedetailleerde head-to-head vergelijkingen met prijzen, energieverbruik, gebruiksgemak en 
        de verborgen nadelen die fabrikanten liever niet vertellen.
      </p>
      <p class="mt-3 text-sm text-muted">
        Alle links verwijzen naar <strong>Amazon NL</strong> (tag: kieskeukennl-21). Koop je via onze link? Dan ontvangen wij 
        een kleine commissie zonder extra kosten voor jou. <a href="/over/" class="text-leaf underline hover:text-[#1f514b]">Lees hoe we werken →</a>
      </p>

      <!-- Quick category nav -->
      <nav class="mt-6 flex flex-wrap gap-2">
        {Object.entries(vsByCategory).filter(([_, cat]) => cat.articles.length > 0).map(([key, cat]) => (
          <a href={`#${key}`} class="rounded border border-[#dfe8e5] px-4 py-2 text-sm font-semibold text-leaf hover:bg-[#edf4f2] transition">
            {cat.emoji} {cat.label} ({cat.articles.length})
          </a>
        ))}
      </nav>
    </div>
  </section>

  <!-- PER-CATEGORY VS SECTIONS -->
  {Object.entries(vsByCategory).filter(([_, cat]) => cat.articles.length > 0).map(([key, cat]) => (
    <section id={key} class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8 border-t border-[#e8e1d7]">
      <h2 class="font-serif text-3xl font-semibold text-ink mb-2">
        {cat.emoji} {cat.label}
      </h2>
      <p class="text-muted mb-6 max-w-3xl">
        {key === 'keuken' && 'Van koffie tot koken: welke keukenapparaten passen het beste bij jouw kookstijl, budget en keukenruimte? We zetten ze recht tegenover elkaar — geen marketingpraat, alleen feiten.'}
        {key === 'schoonmaken' && 'De juiste stofzuiger kiezen is lastiger dan je denkt. Met zak of zakloos? Draadloos of met snoer? Robot of handmatig? Onze vergelijkingen helpen je door de ruis heen.'}
        {key === 'huishoudelijk' && 'Wasdroger of wasmachine-combinatie? Condens of warmtepomp? Deze keuzes hebben impact op je energierekening én je dagelijkse routine. We rekenen het voor in euro\'s per jaar.'}
        {key === 'tuin' && 'Buitenapparaten zijn vaak een flinke investering. Onze vergelijkingen wegen prijs, vermogen, gebruiksgemak en onderhoud tegen elkaar af.'}
      </p>

      <div class="grid gap-4 md:grid-cols-2">
        {cat.articles.sort((a: any, b: any) => b.data.rating - a.data.rating).map((article: any) => {
          const d = article.data;
          return (
            <a href={`/${d.slug}/`} class="group block rounded-lg border border-[#e6ded2] bg-paper p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-md">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <h3 class="font-serif text-lg font-semibold text-ink group-hover:text-leaf transition leading-snug">
                    {d.title}
                  </h3>
                  <p class="mt-1.5 text-sm text-muted line-clamp-2">{d.description}</p>
                </div>
                <span class="shrink-0 rounded bg-[#edf4f2] px-2 py-0.5 text-xs font-bold text-leaf">
                  ⭐ {d.rating.toFixed(1)}
                </span>
              </div>

              {/* Quick comparison highlights */}
              <div class="mt-3 flex flex-wrap items-center gap-2 text-xs text-muted">
                <span class="inline-flex items-center gap-1 rounded bg-linen px-2 py-0.5">
                  {d.priceRange}
                </span>
                <span>{d.readingTime} leestijd</span>
                {d.products?.[0] && (
                  <span class="font-medium text-ink">Topmodel: {d.products[0].name}</span>
                )}
              </div>

              {/* Pros preview */}
              <div class="mt-3 flex flex-wrap gap-1.5">
                {d.pros.slice(0, 3).map((pro: string) => (
                  <span class="inline-flex items-center gap-1 rounded-full bg-[#edf4f2] px-2.5 py-0.5 text-xs text-leaf">
                    + {pro.slice(0, 35)}{pro.length > 35 ? '…' : ''}
                  </span>
                ))}
              </div>

              <div class="mt-3 flex items-center gap-2">
                <span class="rounded bg-leaf px-3 py-1.5 text-xs font-bold text-white group-hover:bg-[#1f514b] transition">
                  Vergelijk direct →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    </section>
  ))}

  <!-- QUICK SUMMARY TABLE -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 border-t border-[#e8e1d7]">
    <h2 class="font-serif text-3xl font-semibold text-ink mb-4">Samenvatting: Alle {vsArticles.length} vergelijkingen in één oogopslag</h2>
    <p class="text-muted mb-6 max-w-3xl">
      Kies hieronder je vergelijking. Iedere gids bevat minimaal 5 productaanbevelingen, 
      een eerlijke prijsvergelijking, en duidelijke uitleg over de verborgen voor- en nadelen van elk apparaattype.
    </p>
    <div class="overflow-x-auto rounded border border-[#e8e1d7]">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="bg-[#f8f5f0] text-left">
            <th class="p-3 font-semibold">Vergelijking</th>
            <th class="p-3 font-semibold">Categorie</th>
            <th class="p-3 font-semibold">Rating</th>
            <th class="p-3 font-semibold">Prijsrange</th>
            <th class="p-3 font-semibold">Leestijd</th>
            <th class="p-3 font-semibold">Link</th>
          </tr>
        </thead>
        <tbody>
          {vsArticles.sort((a: any, b: any) => b.data.rating - a.data.rating).map((article: any, idx: number) => {
            const d = article.data;
            const catLabel = { keuken: 'Keuken', schoonmaken: 'Schoonmaken', huishoudelijk: 'Huishoudelijk', tuin: 'Tuin' }[d.category] || d.category;
            return (
              <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-[#faf8f3]'}>
                <td class="p-3 font-medium max-w-xs">
                  <a href={`/${d.slug}/`} class="text-ink hover:text-leaf transition">
                    {d.title}
                  </a>
                </td>
                <td class="p-3 text-muted">{catLabel}</td>
                <td class="p-3"><span class="inline-flex items-center gap-1"><span class="text-amber-500">★</span> {d.rating.toFixed(1)}</span></td>
                <td class="p-3 text-muted">{d.priceRange}</td>
                <td class="p-3 text-muted">{d.readingTime}</td>
                <td class="p-3">
                  <a href={`/${d.slug}/`} class="inline-block rounded bg-leaf px-3 py-1 text-xs font-bold text-white hover:bg-[#1f514b] transition">
                    Vergelijk →
                  </a>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 border-t border-[#e8e1d7]">
    <h2 class="font-serif text-3xl font-semibold text-ink mb-8">Veelgestelde vragen over apparaten vergelijken</h2>
    <div class="grid gap-5 md:grid-cols-2">
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Welke airfryer is beter: Philips of een goedkoper alternatief?</h3>
        <p class="mt-2 text-sm text-muted">Philips Airfryers hebben consistent de beste reviews dankzij hun Rapid Air-technologie en bouwkwaliteit. Een goedkoper alternatief zoals Inventum of Princess biedt 80-90% van de prestaties voor de helft van de prijs. Lees onze <a href="/beste-airfryer-2026/" class="text-leaf underline hover:text-[#1f514b]">volledige airfryer vergelijking</a>.</p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Robotstofzuiger of gewone stofzuiger — wat is beter?</h3>
        <p class="mt-2 text-sm text-muted">Een robotstofzuiger is ideaal voor dagelijks onderhoud, maar vervangt een gewone stofzuiger niet volledig. Voor dieptereiniging, trappen en hoeken heb je nog steeds een traditionele stofzuiger nodig. <a href="/robotstofzuiger-vs-stofzuiger-2026/" class="text-leaf underline hover:text-[#1f514b]">Lees de volledige vergelijking →</a></p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Is inductie koken echt zuiniger dan gas?</h3>
        <p class="mt-2 text-sm text-muted">Ja, inductie is 50% energiezuiniger dan gas. Het verwarmt de pan direct zonder energieverlies naar de omgeving. Met de huidige gasprijzen verdien je de investering in 3-4 jaar terug. <a href="/inductie-vs-gasfornuis-2026/" class="text-leaf underline hover:text-[#1f514b]">Bekijk onze inductie vs gas vergelijking →</a></p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Warmtepompdroger of condensdroger?</h3>
        <p class="mt-2 text-sm text-muted">Een warmtepompdroger gebruikt 50-60% minder energie en is binnen 2 jaar terugverdiend. Wel droogt hij langzamer (130 vs 90 minuten). <a href="/condensdroger-vs-warmtepompdroger-2026/" class="text-leaf underline hover:text-[#1f514b]">Volledige vergelijking warmtepompdroger vs condensdroger →</a></p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Quooker of waterkoker: wat is de beste keuze?</h3>
        <p class="mt-2 text-sm text-muted">Een Quooker (€1.200-1.800) is luxe die direct kokend water levert. Een waterkoker (€15-80) doet hetzelfde in 2-3 minuten. <a href="/waterkoker-vs-quooker-2026/" class="text-leaf underline hover:text-[#1f514b]">Lees de volledige Quooker vs waterkoker analyse →</a></p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Espresso of filterkoffie — wat past bij mij?</h3>
        <p class="mt-2 text-sm text-muted">Espresso is intenser en geconcentreerder, filterkoffie is milder en beter voor grotere hoeveelheden. De keuze hangt af van je smaak, budget en hoeveel koppen je dagelijks drinkt. <a href="/espresso-vs-filterkoffie-2026/" class="text-leaf underline hover:text-[#1f514b]">Vergelijk espresso vs filterkoffie →</a></p>
      </div>
    </div>
  </section>

  <!-- CROSS-LINK CTA -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8 border-t border-[#e8e1d7]">
    <div class="rounded-lg bg-[#f3faf7] border border-[#dfe8e5] p-8 text-center">
      <h2 class="font-serif text-2xl font-semibold text-ink">Nog niet zeker? Bekijk meer koopgidsen</h2>
      <p class="mt-2 text-muted max-w-xl mx-auto">
        Liever eerst een overzicht van alle {allReviews.length} apparaten? Of meteen de top 15 beste keuzes van 2026 bekijken?
      </p>
      <div class="mt-5 flex flex-wrap justify-center gap-3">
        <a href="/alle-apparaten/" class="rounded bg-leaf px-5 py-2.5 text-sm font-bold text-white hover:bg-[#1f514b] transition">
          Alle {allReviews.length} apparaten in één tabel →
        </a>
        <a href="/vergelijkingen/" class="rounded bg-leaf px-5 py-2.5 text-sm font-bold text-white hover:bg-[#1f514b] transition">
          🆚 Alle 51 directe vergelijkingen →
        </a>
        <a href="/vergelijking/" class="rounded border border-leaf bg-white px-5 py-2.5 text-sm font-bold text-leaf hover:bg-[#edf4f2] transition">
          Per productgroep →
        </a>
        <a href="/top-15/" class="rounded border border-leaf bg-white px-5 py-2.5 text-sm font-bold text-leaf hover:bg-[#edf4f2] transition">
          Top 15 van 2026 →
        </a>
        <a href="/budget/" class="rounded border border-[#cbbda9] px-5 py-2.5 text-sm font-bold text-ink hover:bg-paper transition">
          Budget apparaten onder €100 →
        </a>
        <a href="/energiezuinige-apparaten/" class="rounded border border-[#cbbda9] px-5 py-2.5 text-sm font-bold text-ink hover:bg-paper transition">
          Energiezuinige apparaten →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
