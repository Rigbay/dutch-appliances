---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews', ({ data }) => !data.draft);
const keukenReviews = allReviews.filter(r => r.data.category === 'keuken');

// Build slug set for fast lookup
const has = (d, ...keywords) => keywords.some(kw => d.slug && d.slug.includes(kw));

// Sub-categories for better organization
const subCategories = {
  airfryers: keukenReviews.filter(r => has(r.data, 'airfryer', 'friteuse')),
  koffie: keukenReviews.filter(r => has(r.data, 'koffie', 'nespresso', 'senseo')),
  koeling: keukenReviews.filter(r => has(r.data, 'koelkast', 'vriezer')),
  koken: keukenReviews.filter(r => has(r.data, 'kookplaat', 'magnetron', 'stoomoven', 'afzuigkap')),
  klein: keukenReviews.filter(r => has(r.data, 'mixer', 'waterkoker', 'broodrooster', 'tosti', 'slowcooker', 'keukenmachine', 'sapcentrifuge', 'slowjuicer', 'citruspers')),
  vaat: keukenReviews.filter(r => has(r.data, 'vaatwasser')),
};
