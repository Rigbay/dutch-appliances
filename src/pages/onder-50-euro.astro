---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const reviews = (await getCollection('reviews', ({ data }) => !data.draft));

// Extract all individual products with price ≤ €50
function extractMinPrice(priceRange: string): number {
  const nums = priceRange.match(/\d+/g);
  if (!nums || nums.length === 0) return 999;
  return parseInt(nums[0], 10);
}

interface BudgetProduct {
  name: string;
  priceLow: number;
  priceRange: string;
  rating: number;
  verdict: string;
  bestFor: string;
  affiliateLink: string;
  articleTitle: string;
  articleSlug: string;
  articleRating: number;
  category: string;
}

const categoryLabels: Record<string, { label: string; emoji: string }> = {
  keuken: { label: 'Keuken', emoji: '🍳' },
  schoonmaken: { label: 'Schoonmaken', emoji: '🧹' },
  huishoudelijk: { label: 'Huishoudelijk', emoji: '🏠' },
  tuin: { label: 'Tuin', emoji: '🌿' },
  overig: { label: 'Overig', emoji: '📦' },
};

const allProducts: BudgetProduct[] = [];

for (const review of reviews) {
  const d = review.data;
  for (const p of d.products || []) {
    const pLow = extractMinPrice(p.priceRange || '');
    if (pLow <= 50) {
      allProducts.push({
        name: p.name.replace(/\*\*/g, '').trim(),
        priceLow: pLow,
        priceRange: p.priceRange || '',
        rating: p.rating || 0,
        verdict: p.verdict || '',
        bestFor: p.bestFor || '',
        affiliateLink: p.affiliateLink || '',
        articleTitle: d.title,
        articleSlug: d.slug,
        articleRating: d.rating || 0,
        category: d.category || 'overig',
      });
    }
  }
}

// Sort by price ascending
allProducts.sort((a, b) => a.priceLow - b.priceLow);

// Group by price bracket
const brackets = [
  { label: 'Onder €15', max: 15, emoji: '🪙' },
  { label: '€15 – €25', min: 15, max: 25, emoji: '💵' },
  { label: '€25 – €35', min: 25, max: 35, emoji: '💰' },
  { label: '€35 – €50', min: 35, max: 50, emoji: '🏷️' },
];

const grouped = brackets.map(b => {
  const items = allProducts.filter(p => {
    if (b.min !== undefined) return p.priceLow >= b.min && p.priceLow < b.max;
    return p.priceLow < b.max;
  });
  return { ...b, items };
}).filter(g => g.items.length > 0);

// Category counts
const catCounts: Record<string, number> = {};
for (const p of allProducts) {
  catCounts[p.category] = (catCounts[p.category] || 0) + 1;
}

// FAQ structured data
const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Welke huishoudelijke apparaten zijn de beste koop onder €50 in 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: `In 2026 zijn de beste apparaten onder €50: waterkokers (vanaf €15), broodroosters (vanaf €25), staafmixers (vanaf €20), keukenweegschalen (vanaf €8), kruimeldieven (vanaf €25) en compacte airfryers (vanaf €50). Onze selectie van ${allProducts.length} producten beslaat keuken, schoonmaken, huishoudelijk en tuin — allemaal met Amazon NL affiliate links.`,
      },
    },
    {
      '@type': 'Question',
      name: 'Zijn apparaten onder €50 de moeite waard?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Voor lichte tot gemiddelde gebruiksintensiteit absoluut. Een waterkoker van €20 kookt net zo snel als een van €80. Voor dagelijks intensief gebruik (bijv. airfryer voor een gezin) adviseren we vaak modellen in de €70-150 range. Onze gidsen benoemen eerlijk de minpunten per product.',
      },
    },
    {
      '@type': 'Question',
      name: 'Waar kan ik deze budgetapparaten kopen?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Alle apparaten op deze pagina zijn verkrijgbaar via Amazon.nl. Onze links bevatten de tag kieskeukennl-21 — u betaalt niets extra, wij ontvangen een kleine commissie die onze onafhankelijke reviews ondersteunt.',
      },
    },
    {
      '@type': 'Question',
      name: 'Wat is het verschil tussen apparaten onder €50 en onder €100?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Apparaten onder €50 zijn vooral geschikt voor basisfuncties en lichte gebruikers. Tussen €50-100 vindt u vaak modellen met extra functies (temperatuurregeling op waterkokers, grotere capaciteit airfryers, stillere stofzuigers). Bekijk ook onze budgetgids onder €100 voor meer opties.',
      },
    },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Beste Apparaten onder €50 — 2026',
  description: `${allProducts.length} beste huishoudelijke apparaten onder €50 in 2026. Budget waterkokers, airfryers, stofzuigers, broodroosters en meer met Amazon NL affiliate links.`,
  numberOfItems: allProducts.length,
  itemListElement: allProducts.slice(0, 30).map((p, idx) => ({
    '@type': 'ListItem',
    position: idx + 1,
    item: {
      '@type': 'Product',
      name: p.name,
      url: `https://rigbay.github.io/dutch-appliances/${p.articleSlug}/`,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price: p.priceLow,
        availability: 'https://schema.org/InStock',
        url: p.affiliateLink,
      },
    },
  })),
};
---

<BaseLayout
  title="Beste Apparaten onder €50 in 2026: Top budgetkeuzes per categorie | Beste Apparaten"
  description={`${allProducts.length} beste huishoudelijke apparaten onder €50 in 2026. Budget airfryers, waterkokers, stofzuigers, broodroosters en meer met Amazon NL affiliate links (kieskeukennl-21).`}
  structuredData={[faqSchema, itemListSchema]}
>
  <!-- Hero -->
  <section class="border-b border-[#e8e1d7] bg-gradient-to-b from-linen to-paper">
    <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
      <p class="text-sm font-bold uppercase tracking-[0.16em] text-leaf">Budget koopgidsen</p>
      <h1 class="mt-3 font-serif text-4xl font-semibold text-ink sm:text-5xl">
        Beste apparaten onder €50 in 2026
      </h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-muted">
        {allProducts.length} budgetkeuzes voor keuken, schoonmaken, huishoudelijk en tuin — elk product met directe Amazon NL affiliate link, rating en prijs. Van waterkoker tot airfryer, van kruimeldief tot broodrooster.
      </p>
      
      <!-- Quick stats -->
      <div class="mt-6 flex flex-wrap gap-3">
        {Object.entries(catCounts).map(([cat, count]) => (
          <a href={`#${cat}`} class="inline-flex items-center gap-1.5 rounded border border-[#dfe8e5] px-3 py-1.5 text-sm font-semibold text-leaf hover:bg-[#edf4f2] transition">
            {categoryLabels[cat]?.emoji || '📦'} {categoryLabels[cat]?.label || cat} ({count})
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Products by price bracket -->
  {
    grouped.map(bracket => (
      <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
        <h2 class="font-serif text-3xl font-semibold text-ink">
          {bracket.emoji} {bracket.label} <span class="text-lg font-normal text-muted">({bracket.items.length} producten)</span>
        </h2>
        <div class="mt-5 overflow-x-auto rounded border border-[#e8e1d7]">
          <table class="min-w-full text-sm">
            <thead>
              <tr class="bg-[#f8f5f0] text-left">
                <th class="p-3 font-semibold">Product</th>
                <th class="p-3 font-semibold">Categorie</th>
                <th class="p-3 font-semibold">Prijs v.a.</th>
                <th class="p-3 font-semibold">Rating</th>
                <th class="p-3 font-semibold">Beste voor</th>
                <th class="p-3 font-semibold">Kopen</th>
              </tr>
            </thead>
            <tbody>
              {bracket.items.map((p, idx) => (
                <tr class={idx % 2 === 0 ? 'bg-white' : 'bg-[#faf8f3]'}>
                  <td class="p-3 font-medium max-w-xs">
                    <a href={`/${p.articleSlug}/`} class="text-ink hover:text-leaf transition">
                      {p.name}
                    </a>
                    <div class="text-xs text-muted mt-0.5">{p.verdict.slice(0, 80)}{p.verdict.length > 80 ? '…' : ''}</div>
                  </td>
                  <td class="p-3 text-muted">{categoryLabels[p.category]?.emoji} {categoryLabels[p.category]?.label || p.category}</td>
                  <td class="p-3 font-semibold text-leaf">€{p.priceLow}</td>
                  <td class="p-3">
                    <span class="inline-flex items-center gap-1">
                      <span class="text-amber-500">★</span> {p.rating.toFixed(1)}
                    </span>
                  </td>
                  <td class="p-3 text-muted text-xs max-w-[140px]">{p.bestFor}</td>
                  <td class="p-3">
                    <a href={p.affiliateLink} rel="nofollow sponsored" target="_blank" 
                       class="inline-block rounded bg-[#232f3e] px-3 py-1 text-xs font-bold text-white hover:bg-[#131921] transition">
                      Amazon →
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))
  }

  <!-- Cross-links -->
  <section class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:px-8">
    <div class="rounded border border-[#dfe8e5] bg-[#f3faf7] p-6">
      <h3 class="font-serif text-2xl font-semibold text-ink">Meer budgetopties</h3>
      <p class="mt-2 text-muted">Niet gevonden wat je zocht? Bekijk ook onze andere overzichten:</p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a href="/budget/" class="rounded bg-leaf px-4 py-2 text-sm font-bold text-white hover:bg-[#1f514b] transition">Budget onder €100 ({reviews.filter(r => extractMinPrice(r.data.priceRange) < 100).length} apparaten) →</a>
        <a href="/alle-apparaten/" class="rounded border border-leaf bg-white px-4 py-2 text-sm font-bold text-leaf hover:bg-[#edf4f2] transition">Alle {reviews.length} apparaten →</a>
        <a href="/top-15/" class="rounded border border-[#cbbda9] px-4 py-2 text-sm font-bold text-ink hover:bg-paper transition">Top 15 van 2026 →</a>
        <a href="/" class="rounded border border-[#cbbda9] px-4 py-2 text-sm font-bold text-ink hover:bg-paper transition">Home →</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
    <h2 class="font-serif text-3xl font-semibold text-ink">Veelgestelde vragen over apparaten onder €50</h2>
    <div class="mt-6 grid gap-4 md:grid-cols-2">
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Welke apparaten zijn de beste koop onder €50?</h3>
        <p class="mt-2 text-sm text-muted">Waterkokers (vanaf €15), broodroosters (vanaf €25), staafmixers (vanaf €20) en keukenweegschalen (vanaf €8) bieden de beste prijs-kwaliteit. Voor schoonmaken scoren kruimeldieven (vanaf €25) goed. Compacte airfryers beginnen bij €50.</p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Zijn apparaten onder €50 de moeite waard?</h3>
        <p class="mt-2 text-sm text-muted">Voor lichte tot gemiddelde gebruiksintensiteit absoluut. Een waterkoker van €20 kookt net zo snel als een van €80. Voor dagelijks intensief gebruik adviseren we vaak modellen in de €70-150 range.</p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Waar kan ik deze apparaten kopen?</h3>
        <p class="mt-2 text-sm text-muted">Alle apparaten op deze pagina zijn verkrijgbaar via Amazon.nl. Onze links bevatten tag kieskeukennl-21 — u betaalt niets extra, wij ontvangen een kleine commissie.</p>
      </div>
      <div class="rounded border border-[#e8e1d7] bg-paper p-5">
        <h3 class="font-semibold text-ink">Wat is het verschil met apparaten onder €100?</h3>
        <p class="mt-2 text-sm text-muted">Onder €50 vindt u vooral basisfuncties. Tussen €50-100 krijgt u vaak extra functies zoals temperatuurregeling, grotere capaciteit of stillere motoren. <a href="/budget/" class="text-leaf underline hover:text-[#1f514b]">Bekijk onze budgetgids onder €100</a> voor meer opties.</p>
      </div>
    </div>
  </section>
</BaseLayout>
