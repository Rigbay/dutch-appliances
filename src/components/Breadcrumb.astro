---
export interface Props {
  category: string;
  categoryLabel: string;
  featuredProduct: string;
}

const { category, categoryLabel, featuredProduct } = Astro.props;
---
<nav aria-label="Breadcrumb" class="mx-auto max-w-6xl px-4 pb-2 pt-4 sm:px-6 lg:px-8">
  <ol class="flex flex-wrap items-center gap-1.5 text-sm text-muted">
    <li>
      <a href="/" class="hover:text-leaf hover:underline">Home</a>
    </li>
    <li aria-hidden="true" class="select-none">/</li>
    <li>
      <a href={`/categorie/${category}/`} class="hover:text-leaf hover:underline">{categoryLabel}</a>
    </li>
    <li aria-hidden="true" class="select-none">/</li>
    <li class="truncate max-w-[240px] font-medium text-ink">
      {featuredProduct}
    </li>
  </ol>
</nav>
