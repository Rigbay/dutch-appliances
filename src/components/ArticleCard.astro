---
import type { CollectionEntry } from 'astro:content';

interface Props {
  article: CollectionEntry<'reviews'>;
}

const { article } = Astro.props;
const data = article.data;
const categoryLabel = {
  huishoudelijk: 'Huishoudelijk',
  keuken: 'Keuken',
  schoonmaken: 'Schoonmaken',
  tuin: 'Tuin'
}[data.category];
---

<article class="flex h-full flex-col rounded border border-[#e6ded2] bg-paper p-5 shadow-sm transition hover:-translate-y-0.5 hover:shadow-soft">
  <div class="flex items-center justify-between gap-3 text-xs font-bold uppercase tracking-[0.14em] text-muted">
    <span>{categoryLabel}</span>
    <span>{data.modelYear}</span>
  </div>
  <h2 class="mt-4 font-serif text-2xl font-semibold leading-tight text-ink">
    <a href={`/${data.slug}/`} class="hover:text-leaf">{data.title}</a>
  </h2>
  <p class="mt-3 flex-1 text-sm leading-6 text-muted">{data.description}</p>
  <div class="mt-5 flex flex-wrap items-center gap-2 text-sm">
    <span class="rounded bg-[#edf4f2] px-2.5 py-1 font-bold text-leaf">{data.rating.toFixed(1)}/5</span>
    <span class="rounded bg-linen px-2.5 py-1 text-muted">{data.priceRange}</span>
    <span class="rounded bg-linen px-2.5 py-1 text-muted">{data.readingTime}</span>
  </div>
  <a href={`/${data.slug}/`} class="mt-5 inline-flex w-fit rounded bg-leaf px-4 py-2 text-sm font-bold text-white transition hover:bg-[#1f514b]">
    Lees koopgids
  </a>
</article>
